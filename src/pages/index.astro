---
import Base from '../layouts/Base.astro'
import Logo from '../components/Logo.astro'
import Icon from '../components/Icon.astro'
import VersionBadge from '../components/VersionBadge.tsx'
import TypedHero from '../components/TypedHero.tsx'
import { featureGroups, highlights } from '../data/features.ts'

const heroNav = [
  { label: 'Demo', href: 'https://demo.audiosilo.app', external: true },
  { label: 'Download', href: '/download', external: false },
  { label: 'Docs', href: '/docs', external: false },
  { label: 'Support', href: 'https://discord.gg/vfQMqkzQrf', external: true },
]
---
<Base solidHeader={false}>
  <!-- Hero -->
  <section class="md:h-[1000px] lg:h-[1200px]">
    <div class="bg-cover bg-center" style="background-image: url('/bg2.jpg')">
      <div class="bg-gray-800/50">
        <div
          class="container py-4 lg:py-12 flex flex-col justify-between md:h-[660px] lg:h-[860px]"
        >
          <!-- Top nav -->
          <div class="flex flex-col md:flex-row justify-between items-center gap-3">
            <a class="flex items-center" href="/">
              <Logo class="w-12 lg:w-18 mr-2 lg:mr-4 transform rotate-180" />
              <div class="flex flex-col">
                <div
                  class="text-lg lg:text-2xl uppercase text-pink-600 leading-none tracking-wider"
                >
                  Audio<span class="text-gray-300">Silo</span>
                </div>
                <div class="hidden lg:block leading-none text-xs text-gray-300/80 mt-1">
                  Powered by AudioSilo Server <VersionBadge
                    client:load
                    className="text-pink-600"
                  />
                </div>
              </div>
            </a>
            <nav class="text-gray-300 flex items-center gap-4 sm:gap-5">
              {
                heroNav.map((item) =>
                  item.external ? (
                    <a class="hover:text-pink-600" href={item.href} target="_blank" rel="noopener">
                      {item.label}
                    </a>
                  ) : (
                    <a class="hover:text-pink-600" href={item.href}>
                      {item.label}
                    </a>
                  )
                )
              }
            </nav>
          </div>

          <!-- Hero content -->
          <div class="flex flex-col justify-evenly mt-12 items-center">
            <div class="text-gray-300/80 text-center rounded p-4">
              <p>
                Built <span class="text-pink-600">by</span> audiobook lovers
                <span class="text-pink-600">for</span> audiobook lovers
              </p>
              <TypedHero client:load />
              <div class="max-w-3xl mb-8 mx-auto">
                <p class="mb-2 text-lg leading-loose">
                  AudioSilo is a multi-platform audiobook player &mdash; native apps for iOS and
                  Android plus an installable web PWA, all from one codebase. It includes variable
                  playback speed, a sleep timer with shake-to-cancel, light and dark themes,
                  bookmarks, markdown notes, fast search, listening history and offline downloads,
                  with your progress synced across every device.
                </p>
              </div>
              <div class="flex flex-wrap justify-center gap-4">
                <a
                  href="/download"
                  class="inline-flex items-center gap-2 bg-pink-600 hover:bg-pink-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
                >
                  <Icon name="download" class="w-5 h-5" />
                  Download AudioSilo
                </a>
                <a
                  href="https://demo.audiosilo.app"
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 border border-gray-400 hover:border-pink-600 text-gray-200 px-6 py-3 rounded-lg transition-colors"
                >
                  Try the live demo
                </a>
              </div>
            </div>
            <div class="mt-8 w-full max-w-4xl px-2">
              <img
                src="/shot-desktop.png"
                alt="The AudioSilo web player on desktop, showing the library and continue-listening"
                class="w-full h-auto drop-shadow-[0_30px_60px_rgba(0,0,0,0.45)]"
                width="1800"
                height="1125"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Highlights -->
  <section class="container py-10">
    <div class="flex flex-wrap justify-center gap-3">
      {
        highlights.map((h) => (
          <div class="flex items-center gap-2 bg-white rounded-full shadow-sm border border-gray-200 px-4 py-2 text-sm text-gray-700">
            <Icon name={h.icon} class="w-4 h-4 text-pink-600" />
            <span>{h.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Features -->
  <section class="container pb-6 pt-4">
    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-pink-800">
        Everything you need to run your own audiobook library
      </h2>
      <p class="text-gray-600 mt-3 max-w-2xl mx-auto">
        An open-source server and a polished cross-platform player, built together for one purpose.
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {
        featureGroups.map((group) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-3">
              <span class="flex items-center justify-center w-11 h-11 rounded-lg bg-pink-100 text-pink-600">
                <Icon name={group.icon} class="w-6 h-6" />
              </span>
              <h3 class="text-xl font-semibold text-pink-800">{group.title}</h3>
            </div>
            <p class="text-gray-600 mb-4">{group.intro}</p>
            <ul class="space-y-2">
              {group.points.map((point) => (
                <li class="flex gap-2 text-sm text-gray-700">
                  <Icon name="check" class="w-4 h-4 text-pink-600 flex-shrink-0 mt-0.5" />
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Device strip -->
  <section class="container py-14">
    <h2 class="text-center text-3xl font-extrabold text-pink-800 mb-2">Looks great everywhere</h2>
    <p class="text-center text-gray-600 mb-10 max-w-2xl mx-auto">
      From your phone on the commute to the big screen at home &mdash; the same library, in sync.
    </p>
    <div class="flex flex-col md:flex-row items-center justify-center gap-10 md:gap-14">
      <img
        src="/shot-desktop-book.png"
        class="w-full max-w-2xl h-auto drop-shadow-[0_25px_50px_rgba(0,0,0,0.28)]"
        alt="AudioSilo book detail with the player panel on desktop"
      />
      <img
        src="/shot-phone.png"
        class="w-48 md:w-56 h-auto drop-shadow-[0_25px_45px_rgba(0,0,0,0.3)]"
        alt="The AudioSilo player on a phone"
      />
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-800 text-gray-100">
    <div class="container py-14 text-center">
      <h2 class="text-3xl font-extrabold mb-3">Ready to host your own audiobooks?</h2>
      <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
        Run the server with Docker in minutes, then connect the apps. Your library, your hardware,
        your rules &mdash; no data handed to anyone else.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/download"
          class="inline-flex items-center gap-2 bg-pink-600 hover:bg-pink-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          <Icon name="download" class="w-5 h-5" />
          Download AudioSilo
        </a>
        <a
          href="/docs"
          class="inline-flex items-center gap-2 border border-gray-500 hover:border-pink-600 text-gray-200 px-6 py-3 rounded-lg transition-colors"
        >
          Read the docs
          <Icon name="arrowRight" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </section>
</Base>
