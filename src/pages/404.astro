---
import Base from '../layouts/Base.astro'
import Button from '../components/Button.astro'
import Waveform from '../components/Waveform.astro'
import Icon from '../components/Icon.astro'
---
<Base
  hasHero
  title="Page not found - AudioSilo"
  description="This page doesn't exist. Head back to the AudioSilo home page."
>
  <section class="relative overflow-hidden">
    <div class="glow left-1/2 top-1/4 h-[24rem] w-[34rem] -translate-x-1/2"></div>
    <div class="container relative z-10 flex min-h-[70vh] flex-col items-center justify-center py-20 text-center">
      <span class="mb-6 text-sm font-semibold uppercase tracking-[0.3em] text-pink-500">404</span>
      <Waveform class="mb-8 opacity-70" />
      <h1 class="text-4xl font-black tracking-tight text-hi sm:text-5xl">
        This chapter doesn't exist.
      </h1>
      <p class="mx-auto mt-5 max-w-md text-lg leading-relaxed text-body">
        The page you were after has moved or was never here. Let's get you back to the shelf.
      </p>
      <div class="mt-8">
        <Button href="/">
          <Icon name="arrowRight" class="h-5 w-5" /> Back to home
        </Button>
      </div>
    </div>
  </section>
</Base>
