---
import Button from '../Button.astro'
import Badge from '../Badge.astro'
import Waveform from '../Waveform.astro'
import Equalizer from '../Equalizer.astro'
import Icon from '../Icon.astro'
---
<section class="relative overflow-hidden">
  <!-- Soft radial glow behind the hero. -->
  <div class="glow left-1/2 top-24 h-[520px] w-[880px] max-w-[95vw] -translate-x-1/2"></div>

  <div class="container relative z-10 pt-16 pb-10 sm:pt-24 lg:pt-28">
    <!-- Copy block -->
    <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
      <Badge variant="pink" class="reveal is-visible">
        <Icon name="shield" class="h-3.5 w-3.5" />
        Open source · self-hosted · no subscription
      </Badge>

      <h1
        class="mt-6 text-[clamp(2.75rem,7vw,5.5rem)] font-black leading-[1.02] tracking-[-0.02em] text-hi"
      >
        Your audiobooks.<br />Your <span class="hero-grad">server</span>.<br />Every device.
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-body">
        A self-hosted audiobook player for iOS, Android and the web, backed by its own
        open-source Go server, so your library and your listening stay entirely yours.
      </p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-center">
        <Button href="/download">
          <Icon name="rocket" class="h-5 w-5" />
          Get started
        </Button>
        <Button href="https://demo.audiosilo.app" variant="secondary" external>
          Try the live demo
          <Icon name="arrowRight" class="h-4 w-4" />
        </Button>
      </div>
    </div>

    <!-- Screenshot composition: desktop with the phone overlapping its right edge. -->
    <div class="relative mx-auto mt-14 max-w-5xl sm:mt-16">
      <div class="glow left-1/2 top-10 h-[340px] w-[640px] max-w-[90vw] -translate-x-1/2"></div>

      <div
        class="relative z-10 overflow-hidden rounded-2xl border border-edge bg-surface shadow-2xl shadow-black/50"
      >
        <img
          src="/shot-desktop.png"
          alt="The AudioSilo web player on desktop, showing the library grid and a continue-listening shelf"
          width="3600"
          height="2250"
          class="h-auto w-full"
          fetchpriority="high"
          decoding="async"
        />

      </div>

      <!-- Decorative floating 'now playing' chip, straddling the frame's
           bottom-left edge so it never covers the screenshot's own UI (the
           current shot-desktop.png has the app logo top-left, where this
           chip used to sit). Outside the overflow-hidden card on purpose. -->
      <div
        class="absolute -bottom-3.5 left-6 z-30 hidden items-center gap-2 rounded-full border border-edge bg-deep/90 px-3 py-1.5 text-xs font-medium text-body shadow-lg shadow-black/40 backdrop-blur sm:flex"
      >
        <Equalizer />
        Now playing
      </div>

      <!-- Overlapping looping iOS app demo, in a rounded phone-style frame
           (md+ only; keeps the mobile hero clean). Paused under reduced motion
           by the script below. -->
      <div
        class="absolute -bottom-6 right-[-1rem] z-20 hidden w-40 overflow-hidden rounded-[2rem] border border-edge bg-deep shadow-2xl shadow-black/60 ring-1 ring-white/5 md:block lg:right-2 lg:w-48"
      >
        <video
          id="hero-demo"
          class="block h-auto w-full"
          width="804"
          height="1748"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/ios-app-demo-poster.jpg"
          aria-label="The AudioSilo iOS app in use: browsing a library, opening a book and playing with chapter controls"
        >
          <source src="/ios-app-demo.mp4" type="video/mp4" />
        </video>
      </div>
    </div>

    <!-- Animated waveform strip under the fold. -->
    <div class="mt-14 flex justify-center">
      <Waveform bars={72} animated class="w-full max-w-2xl opacity-70" />
    </div>
  </div>
</section>

<style>
  .hero-grad {
    background: linear-gradient(90deg, #ec4899, #db2777);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
</style>

<script>
  // Respect reduced motion: freeze the looping demo video on its first frame.
  const demo = document.getElementById('hero-demo') as HTMLVideoElement | null
  if (demo && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    demo.removeAttribute('autoplay')
    demo.autoplay = false
    demo.loop = false
    demo.pause()
  }
</script>
