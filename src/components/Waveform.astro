---
// A thin vertical-bar waveform strip used as section punctuation. Bar heights
// are seeded pseudo-random and centre-weighted, so the strip is deterministic
// across builds while still looking varied. A few centre bars are pink; the
// animated variant gently oscillates each bar (staggered, GPU-cheap, frozen
// under prefers-reduced-motion via the .wave-bar rule in global.css).
interface Props {
  bars?: number
  animated?: boolean
  class?: string
}
const { bars = 56, animated = false, class: className = '' } = Astro.props

function mulberry32(seed: number): () => number {
  let a = seed
  return function () {
    a |= 0
    a = (a + 0x6d2b79f5) | 0
    let t = Math.imul(a ^ (a >>> 15), 1 | a)
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296
  }
}

const rand = mulberry32(0x5e3d21)
const mid = (bars - 1) / 2
const items = Array.from({ length: bars }, (_, i) => {
  const dist = Math.abs(i - mid) / mid // 0 at centre, 1 at the edges
  const weight = 1 - dist * dist // centre-weighted
  const height = Math.round(14 + (0.3 + 0.7 * rand()) * weight * 82) // 14..96
  const pink = Math.abs(i - mid) <= 2
  const delay = ((i % 9) * 0.09).toFixed(2)
  return { height, pink, delay }
})
---
<div class={`flex items-center gap-[3px] h-10 ${className}`} aria-hidden="true">
  {
    items.map((b) => (
      <span
        class={`w-[3px] rounded-full ${b.pink ? 'bg-pink-500' : 'bg-edge'} ${animated ? 'wave-bar' : ''}`}
        style={`height:${b.height}%;${animated ? `animation-delay:${b.delay}s` : ''}`}
      />
    ))
  }
</div>
</content>
