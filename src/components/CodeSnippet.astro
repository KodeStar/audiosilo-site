---
import Icon from './Icon.astro'

// Dark code block on bg-raised with a rounded border, an optional filename tab
// and a copy-to-clipboard button (vanilla JS, shows a brief "Copied" state).
// The existing CodeBlock.astro is left untouched for the docs pages.
interface Props {
  code: string
  filename?: string
  class?: string
}
const { code, filename, class: className = '' } = Astro.props
const trimmed = code.trim()
---
<div class={`code-snippet not-prose overflow-hidden rounded-xl border border-edge bg-raised ${className}`}>
  <div class="flex items-center justify-between border-b border-edge px-4 py-2">
    <span class="font-mono text-xs text-dim">{filename ?? ''}</span>
    <button
      type="button"
      class="copy-btn inline-flex items-center gap-1.5 rounded-md px-2 py-1 text-xs text-dim transition-colors hover:text-pink-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-pink-500"
      aria-label="Copy code to clipboard"
    >
      <Icon name="copy" class="h-3.5 w-3.5" />
      <span class="copy-label">Copy</span>
    </button>
  </div>
  <pre class="overflow-x-auto p-4 text-sm leading-relaxed text-body"><code>{trimmed}</code></pre>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.code-snippet .copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.closest('.code-snippet')?.querySelector('code')?.textContent ?? ''
      const label = btn.querySelector<HTMLElement>('.copy-label')
      navigator.clipboard
        .writeText(text)
        .then(() => {
          if (!label) return
          const previous = label.textContent
          label.textContent = 'Copied'
          btn.classList.add('text-pink-400')
          window.setTimeout(() => {
            label.textContent = previous
            btn.classList.remove('text-pink-400')
          }, 1600)
        })
        .catch(() => {
          /* Clipboard unavailable (insecure context); nothing to do. */
        })
    })
  })
</script>
</content>
